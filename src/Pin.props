<?xml version="1.0" encoding="utf-8"?>
<!--
  Pin 3.31 (IA-32 / Windows / MSVC kit) wiring for the PINdemonium pintool.

  Imported ONLY by MyPinTool.vcxproj, and imported LAST (right before the
  Microsoft.Cpp.targets import) so that the values here OVERRIDE the stale
  Pin 2.14 include/lib/define settings that still live inside the .vcxproj.

  Runtime layout is the hardcoded C:\pin\ that the tool expects (unpack the
  kit pin-external-3.31-98869-gfa6f126a8-msvc-windows.zip into C:\pin\).

  Link libraries: CONFIRMED against the 3.31 IA-32 MSVC kit on disk.
  Include directories: standard Pin 3.x layout below; still to confirm against
  this kit's extras\ folder (adjust if a compile fails on a missing PinCRT
  header).  The kit uses a consolidated c++.lib/pincrt.lib, so some legacy
  stlport/libstdc++ include dirs may not all exist — harmless if absent, they
  are simply ignored, but remove any that cause a warning.
-->
<Project>
  <PropertyGroup Label="PinRoot">
    <PIN_ROOT>C:\pin</PIN_ROOT>
  </PropertyGroup>

  <!-- IA-32 (Win32) only. The pintool targets 32-bit PE files exclusively. -->
  <ItemDefinitionGroup Condition="'$(Platform)'=='Win32'">
    <ClCompile>
      <!-- MSVC kit model (mirrors the original Pin 2.14 MSVC project): use
           MSVC's own STL/CRT headers + link pincrt.lib/c++.lib.  Do NOT add
           Pin's Linux/clang libc headers (extras\crt\include) — they use the
           GCC-only #include_next directive that cl.exe rejects (C1021). -->
      <AdditionalIncludeDirectories>$(SolutionDir)Scylla\Scylla;$(PIN_ROOT)\source\include\pin;$(PIN_ROOT)\source\include\pin\gen;$(PIN_ROOT)\source\tools\Utils;$(PIN_ROOT)\source\tools\InstLib;$(PIN_ROOT)\extras\components\include;$(PIN_ROOT)\extras\xed-ia32\include;$(PIN_ROOT)\extras\xed-ia32\include\xed;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
      <!-- Pin 3.x adds __PIN__ and PIN_CRT vs the old 2.14 define set. -->
      <PreprocessorDefinitions>TARGET_IA32;HOST_IA32;TARGET_WINDOWS;__PIN__=1;PIN_CRT=1;BIGARRAY_MULTIPLIER=1;_SECURE_SCL=0;_ITERATOR_DEBUG_LEVEL=0;WIN32;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <!-- MSVC reports __cplusplus==199711L unless /Zc:__cplusplus is passed;
           PinCRT's CXX config header then thinks it is C++03 and #errors on
           alignof.  This makes __cplusplus reflect /std:c++14 (201402L). -->
      <AdditionalOptions>/EHs- /EHa- /Zc:__cplusplus %(AdditionalOptions)</AdditionalOptions>
      <ExceptionHandling>false</ExceptionHandling>
      <RuntimeTypeInfo>false</RuntimeTypeInfo>
      <BufferSecurityCheck>false</BufferSecurityCheck>
      <BasicRuntimeChecks>Default</BasicRuntimeChecks>
    </ClCompile>
    <Link>
      <!-- Confirmed against the 3.31 IA-32 MSVC kit on disk:
             * PinCRT is one lib (pincrt.lib) + crtbeginS.obj, in ia32\runtime\pincrt
             * C++ runtime is c++.lib (in ia32\lib)
             * XED is xed.lib (2.14 was libxed.lib)
             * pinvm.lib and ia32\lib-ext NO LONGER EXIST in 3.31 -> removed
             * Native CRT (libcpmt.lib/libcmt.lib) removed: PinCRT replaces it. -->
      <AdditionalDependencies>crtbeginS.obj;pincrt.lib;pin.lib;c++.lib;xed.lib;ntdll-32.lib;kernel32.lib;ScyllaDLLx86.lib;%(AdditionalDependencies)</AdditionalDependencies>
      <AdditionalLibraryDirectories>$(PIN_ROOT)\ia32\lib;$(PIN_ROOT)\ia32\runtime\pincrt;$(PIN_ROOT)\extras\xed-ia32\lib;C:\pin\PINdemoniumDependencies\Scylla\ScyllaDllRelease;%(AdditionalLibraryDirectories)</AdditionalLibraryDirectories>
      <IgnoreAllDefaultLibraries>true</IgnoreAllDefaultLibraries>
      <AdditionalOptions>/export:main /EXPORT:main %(AdditionalOptions)</AdditionalOptions>
      <EntryPointSymbol>Ptrace_DllMainCRTStartup@12</EntryPointSymbol>
      <BaseAddress>0x55000000</BaseAddress>
      <SubSystem>NotSet</SubSystem>
      <TargetMachine>MachineX86</TargetMachine>
      <OptimizeReferences>false</OptimizeReferences>
    </Link>
  </ItemDefinitionGroup>

</Project>
